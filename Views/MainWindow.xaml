<metro:MetroWindow
    x:Class="BmsLightBridge.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:vm="clr-namespace:BmsLightBridge.ViewModels"
    xmlns:conv="clr-namespace:BmsLightBridge.Converters"
    xmlns:models="clr-namespace:BmsLightBridge.Models"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="BMS Light Bridge v1.0.3"
    Height="780" Width="1280"
    MinHeight="600" MinWidth="900"
    Background="{StaticResource BackgroundBrush}"
    TitleCharacterCasing="Normal"
    GlowBrush="{StaticResource AccentBrush}"
    NonActiveGlowBrush="#181C1F"
    WindowStartupLocation="CenterScreen"
    Icon="pack://application:,,,/Resources/app.ico">
    <metro:MetroWindow.DataContext>
        <vm:MainViewModel/>
    </metro:MetroWindow.DataContext>
    <metro:MetroWindow.Resources>
        <conv:BoolToColorConverter        x:Key="BoolToColor"/>
        <conv:BoolToVisibilityConverter   x:Key="BoolToVisible"/>
        <conv:BoolToVisibilityConverter   x:Key="BoolToHidden" Invert="True"/>
        <conv:BoolToOnOffConverter        x:Key="BoolToOnOff"/>
        <conv:LightStatusBrushConverter   x:Key="LightBrush"/>
        <conv:MappedStatusConverter       x:Key="MappedStatus"/>
        <conv:NullToCollapsedConverter    x:Key="NullToCollapsed"/>
        <conv:StringNullOrEmptyToCollapsedConverter x:Key="NullOrEmptyToCollapsed"/>
        <conv:DeviceTypeToVisibilityConverter x:Key="ArduinoVisible" ShowFor="Arduino"/>
        <conv:DeviceTypeToVisibilityConverter x:Key="WinWingVisible" ShowFor="WinWing"/>
        <!-- Provides the list of JoystickAxis enum values for the axis ComboBox -->
        <ObjectDataProvider x:Key="JoystickAxes"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:JoystickAxis"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </metro:MetroWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Menubalk -->
            <RowDefinition Height="*"/>     <!-- Hoofdinhoud -->
            <RowDefinition Height="Auto"/>  <!-- Statusbalk -->
        </Grid.RowDefinitions>

        <!-- ================================================================
             HEADER BALK
             ================================================================ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Image Grid.Column="0"
                       Source="pack://application:,,,/Resources/logo.png"
                       Height="82" Width="82" Margin="0,0,20,0"
                       Stretch="Uniform" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- Rechterkolom: titel + spacer + toolbar -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                        <TextBlock Text="BMS Light Bridge"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Falcon BMS cockpit lighting synchronisation"
                                   Style="{StaticResource LabelStyle}" FontSize="10"/>
                    </StackPanel>
                    <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource StartButton}"
                            Command="{Binding StartSyncCommand}"
                            Margin="0,0,8,0" Width="110"
                            ToolTip="Start synchronising cockpit lighting from Falcon BMS to connected hardware">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14"
                                                        VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Start Sync" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource StopButton}"
                            Command="{Binding StopSyncCommand}"
                            Width="110" Margin="0,0,8,0"
                            ToolTip="Stop synchronising cockpit lighting">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Stop" Width="14" Height="14"
                                                        VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Stop Sync" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Border CornerRadius="6" Padding="10,6" Margin="0,0,12,0"
                            Background="#1A2226" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding AutoSync, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  ToolTip="Automatically start sync when BMS connects and stop when BMS disconnects">
                            <TextBlock Text="Auto Sync" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </CheckBox>
                    </Border>
                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="0,0,12,0" VerticalAlignment="Stretch"/>
                    <Button Command="{Binding RemoveAllMappingsCommand}"
                            Margin="0,0,8,0"
                            ToolTip="Remove all mappings (confirmation required)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="TrashCan" Width="14" Height="14"
                                                        VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Remove All Mappings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>


                    <!-- Test All Mappings knop -->
                    <Button Command="{Binding TestAllCommand}"
                            Width="150"
                            ToolTip="Turn all mapped lights ON at once. Press again to turn off.">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTestingAll}" Value="True">
                                        <Setter Property="Background" Value="#D4881A"/>
                                        <Setter Property="Foreground" Value="#181C1F"/>
                                    </DataTrigger>
                                    <!-- Disable the button while Arduino boards are still initialising -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsTestingAll}"    Value="True"/>
                                            <Condition Binding="{Binding CanStopAllTests}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity"   Value="0.5"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Width="14" Height="14"
                                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                <iconPacks:PackIconMaterial.Style>
                                    <Style TargetType="iconPacks:PackIconMaterial">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTestingAll}" Value="True">
                                                <Setter Property="Kind" Value="LightbulbOff"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTestingAll}" Value="False">
                                                <Setter Property="Kind" Value="Lightbulb"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </iconPacks:PackIconMaterial.Style>
                            </iconPacks:PackIconMaterial>
                            <TextBlock Text="{Binding TestAllButtonLabel}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    </WrapPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,0,0">
                        <Border Width="160" CornerRadius="6" Padding="10,6" Margin="0,0,6,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBmsConnected}" Value="True">
                                            <Setter Property="Background" Value="#1A3EC98A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsBmsConnected}" Value="False">
                                            <Setter Property="Background" Value="#1AE05C6B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBmsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#3EC98A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsBmsConnected}" Value="False">
                                                    <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <StackPanel>
                                    <TextBlock Text="FALCON BMS" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBmsConnected}" Value="True">
                                                        <Setter Property="Text" Value="Connected"/>
                                                        <Setter Property="Foreground" Value="#3EC98A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsBmsConnected}" Value="False">
                                                        <Setter Property="Text" Value="Not connected"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Width="160" CornerRadius="6" Padding="10,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                            <Setter Property="Background" Value="#1A5A8FAD"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSyncing}" Value="False">
                                            <Setter Property="Background" Value="#1A2226"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                    <Setter Property="Fill" Value="#6B8A9A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSyncing}" Value="False">
                                                    <Setter Property="Fill" Value="#4A606E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <StackPanel>
                                    <TextBlock Text="SYNC" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                                        <Setter Property="Text" Value="Active"/>
                                                        <Setter Property="Foreground" Value="#6B8A9A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSyncing}" Value="False">
                                                        <Setter Property="Text" Value="Inactive"/>
                                                        <Setter Property="Foreground" Value="#4A606E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </Grid> <!-- toolbar Grid -->
                </Grid> <!-- rechter kolom Grid -->
            </Grid> <!-- outer 2-kolom Grid -->
        </Border>

        <!-- ================================================================
             MENUBALK
             ================================================================ -->
        <Border Grid.Row="1"
                Background="#141A1E"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Menu Background="Transparent"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  FontSize="12">
                <Menu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="12,6"/>
                    </Style>
                    <Style TargetType="Separator">
                        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                        <Setter Property="Margin" Value="6,2"/>
                    </Style>
                </Menu.Resources>

                <!-- File -->
                <MenuItem Header="File">
                    <MenuItem Header="Import Config..."
                              ToolTip="Load a previously exported config.json file, replacing the current configuration"
                              Click="MenuImportConfig_Click">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Export Config..."
                              ToolTip="Save a copy of the current configuration to a file"
                              Click="MenuExportConfig_Click">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Exit"
                              ToolTip="Close BmsLightBridge"
                              Click="MenuExit_Click">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="ExitToApp" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <!-- Actions -->
                <MenuItem Header="Actions">
                    <MenuItem Header="Start Sync"
                              Command="{Binding StartSyncCommand}"
                              ToolTip="Start synchronising cockpit lighting from Falcon BMS to connected hardware">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Stop Sync"
                              Command="{Binding StopSyncCommand}"
                              ToolTip="Stop synchronising cockpit lighting">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="Stop" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Test All Mappings"
                              Command="{Binding TestAllCommand}"
                              ToolTip="Turn all mapped lights ON at once to verify your wiring">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="Lightbulb" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Remove All Mappings"
                              Command="{Binding RemoveAllMappingsCommand}"
                              ToolTip="Remove all signal-to-device mappings (confirmation required)">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="TrashCan" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Refresh Devices"
                              Command="{Binding RefreshDevicesCommand}"
                              ToolTip="Scan for connected WinWing controllers and COM ports">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <!-- Settings -->
                <MenuItem Header="Settings">
                    <MenuItem Header="Auto Sync"
                              ToolTip="Automatically start sync when BMS connects, and stop when BMS disconnects"
                              IsCheckable="True"
                              IsChecked="{Binding AutoSync, Mode=TwoWay}">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="Sync" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Start Minimized"
                              ToolTip="Open BmsLightBridge minimized to the taskbar on startup"
                              IsCheckable="True"
                              IsChecked="{Binding StartMinimized, Mode=TwoWay}">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="WindowMinimize" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <!-- Help -->
                <MenuItem Header="Help">
                    <MenuItem Header="About BmsLightBridge"
                              ToolTip="Version information and credits"
                              Click="MenuAbout_Click">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="InformationOutline" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="GitHub Repository"
                              ToolTip="Open the BmsLightBridge GitHub page in your browser"
                              Click="MenuGitHub_Click">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="Github" Width="14" Height="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </Menu>
        </Border>

        <!-- ================================================================
             HOOFD INHOUD - Drie kolommen layout
             ================================================================ -->
        <Grid Grid.Row="2" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>    <!-- Signaallijst -->
                <ColumnDefinition Width="8"/>                    <!-- Splitter -->
                <ColumnDefinition Width="340" MinWidth="280"/>  <!-- Mapping editor -->
            </Grid.ColumnDefinitions>

            <!-- ============================================================
                 LINKER KOLOM: Signaallijst
                 ============================================================ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Zoek & filter -->
                    <RowDefinition Height="*"/>      <!-- Lijst -->
                </Grid.RowDefinitions>

                <!-- Zoek en filter balk -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Zoekbalk -->
                        <Border Grid.Column="0" Background="#1C2226" CornerRadius="6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Margin="8,0,0,0"
                                                            Foreground="{StaticResource TextSecondaryBrush}"
                                                            VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Padding="6,6" FontSize="12"
                                         metro:TextBoxHelper.Watermark="Search signal..."/>
                            </Grid>
                        </Border>

                        <!-- Expand / Collapse All knoppen -->
                        <Button Grid.Column="6"
                                Command="{Binding ExpandAllCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Height="32" Padding="8,0"
                                ToolTip="Expand all categories">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="UnfoldMoreHorizontal" Width="13" Height="13"
                                                            VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Expand all" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="8"
                                Command="{Binding CollapseAllCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Height="32" Padding="8,0"
                                ToolTip="Collapse all categories">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="UnfoldLessHorizontal" Width="13" Height="13"
                                                            VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Collapse all" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Categorie filter -->
                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource DarkComboBox}"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"/>

                        <!-- Mapped Only filter -->
                        <CheckBox Grid.Column="4"
                                  IsChecked="{Binding ShowOnlyMapped, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  ToolTip="Show only mapped signals">
                            <TextBlock Text="Mapped" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </CheckBox>
                    </Grid>
                </Border>

                <!-- Signaallijst -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Kolomhoofden -->
                            <RowDefinition Height="*"/>      <!-- Items -->
                        </Grid.RowDefinitions>

                        <!-- Kolomhoofden -->
                        <Border Grid.Row="0" Background="#1C2226" Padding="12,8"
                                CornerRadius="8,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="●" Style="{StaticResource LabelStyle}" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="SIGNAL" Style="{StaticResource LabelStyle}" FontWeight="SemiBold" Margin="8,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="STATUS" Style="{StaticResource LabelStyle}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="✓" Style="{StaticResource LabelStyle}" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <!-- Inklapbare categorieën -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding CategoryGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                                  Margin="0,0,0,2">
                                            <Expander.Style>
                                                <Style TargetType="Expander">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Expander">
                                                                <StackPanel>
                                                                    <!-- Category header (clickable) -->
                                                                    <Border Background="#1C2226"
                                                                            Padding="12,6"
                                                                            BorderBrush="#2D373D"
                                                                            BorderThickness="0,0,0,1"
                                                                            Cursor="Hand">
                                                                        <Border.InputBindings>
                                                                            <MouseBinding MouseAction="LeftClick"
                                                                                Command="{Binding DataContext.ToggleCategoryCommand,
                                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}"/>
                                                                        </Border.InputBindings>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <!-- Chevron icon -->
                                                                            <iconPacks:PackIconMaterial Grid.Column="0"
                                                                                Width="10" Height="10"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="#6B8A9A"
                                                                                Margin="0,0,8,0">
                                                                                <iconPacks:PackIconMaterial.Style>
                                                                                    <Style TargetType="iconPacks:PackIconMaterial">
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                                <Setter Property="Kind" Value="ChevronDown"/>
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                                                <Setter Property="Kind" Value="ChevronRight"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </iconPacks:PackIconMaterial.Style>
                                                                            </iconPacks:PackIconMaterial>
                                                                            <!-- Category name -->
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="{Binding Name}"
                                                                                       Foreground="#6B8A9A"
                                                                                       FontSize="11"
                                                                                       FontWeight="SemiBold"
                                                                                       VerticalAlignment="Center"/>
                                                                            <!-- Count badge -->
                                                                            <TextBlock Grid.Column="2"
                                                                                       Text="{Binding Signals.Count, StringFormat='({0})'}"
                                                                                       Foreground="#6A7C85"
                                                                                       FontSize="10"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Grid>
                                                                    </Border>

                                                                    <!-- Signals list (shown when expanded) -->
                                                                    <ContentPresenter x:Name="Content"
                                                                                      Visibility="Collapsed"/>
                                                                </StackPanel>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsExpanded" Value="True">
                                                                        <Setter TargetName="Content" Property="Visibility" Value="Visible"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Expander.Style>

                                            <!-- Signal items inside the category -->
                                            <ItemsControl ItemsSource="{Binding Signals}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="12,7"
                                                                BorderBrush="{StaticResource BorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Cursor="Hand">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Background" Value="#1A5A8FAD"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                    Command="{Binding DataContext.SelectSignalCommand,
                                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"/>
                                                            </Border.InputBindings>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="24"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="60"/>
                                                                    <ColumnDefinition Width="24"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Lamp indicator -->
                                                                <Ellipse Grid.Column="0" Width="10" Height="10"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding IsOn, Converter={StaticResource LightBrush}}"/>

                                                                <!-- Naam -->
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Light.Name}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontSize="12" VerticalAlignment="Center"
                                                                           Margin="8,0,0,0"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding IsOn, Converter={StaticResource BoolToOnOff}}"
                                                                           VerticalAlignment="Center" FontSize="11"
                                                                           FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsOn}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#3EC98A"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsOn}" Value="False">
                                                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>

                                                                <!-- Mapping indicator -->
                                                                <CheckBox Grid.Column="3"
                                                                          IsChecked="{Binding IsMapped, Mode=OneWay}"
                                                                          IsHitTestVisible="False"
                                                                          Focusable="False"
                                                                          VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ============================================================
                 RECHTER KOLOM: Mapping editor
                 ============================================================ -->
            <TabControl Grid.Column="2"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                                            BorderThickness="0,0,0,2"
                                            BorderBrush="Transparent"
                                            Background="Transparent">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Tab 1: Signal Mapping -->
                <TabItem Header="Mapping">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                    <!-- Geselecteerd signaal info -->
                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding HasSelectedSignal, Converter={StaticResource BoolToVisible}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="SELECTED SIGNAL" Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding SelectedSignal.Light.Name}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16" FontWeight="SemiBold"/>

                            <TextBlock Text="{Binding SelectedSignal.Light.Category}"
                                       Style="{StaticResource LabelStyle}" Margin="0,2,0,8"/>

                            <!-- Live status indicator -->
                            <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSignal.IsOn}" Value="True">
                                                <Setter Property="Background" Value="#1A3EC98A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedSignal.IsOn}" Value="False">
                                                <Setter Property="Background" Value="#1A2E3D4A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                             Fill="{Binding SelectedSignal.IsOn, Converter={StaticResource BoolToColor}}"/>
                                    <TextBlock Text="{Binding SelectedSignal.IsOn, Converter={StaticResource BoolToOnOff}}"
                                               FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedSignal.IsOn}" Value="True">
                                                        <Setter Property="Foreground" Value="#3EC98A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedSignal.IsOn}" Value="False">
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Geen signaal geselecteerd -->
                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding HasSelectedSignal, Converter={StaticResource BoolToHidden}}">
                        <StackPanel HorizontalAlignment="Center" Margin="0,20">
                            <iconPacks:PackIconMaterial Kind="CursorPointer" Width="32" Height="32"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Select a signal" Style="{StaticResource LabelStyle}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="from the list to map it"
                                       Style="{StaticResource LabelStyle}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Mapping editor (zichtbaar als signaal geselecteerd) -->
                    <StackPanel Visibility="{Binding HasSelectedSignal, Converter={StaticResource BoolToVisible}}">

                        <!-- Device type selectie -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="OUTPUT DEVICE" Margin="0,0,0,12"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Arduino optie -->
                                    <Border Grid.Column="0" CornerRadius="6" Padding="12,8" Cursor="Hand"
                                            BorderThickness="2"
                                            ToolTip="Map this signal to a digital output pin on an Arduino or ESP32">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsArduinoSelected}" Value="True">
                                                        <Setter Property="Background" Value="#1A5A8FAD"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsArduinoSelected}" Value="False">
                                                        <Setter Property="Background" Value="#0A5A8FAD"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.StartSyncCommand,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="Arduino"/>
                                        </Border.InputBindings>
                                        <RadioButton IsChecked="{Binding IsArduinoSelected}"
                                                     GroupName="DeviceType"
                                                     Background="Transparent"
                                                     BorderThickness="0">
                                            <StackPanel>
                                                <TextBlock Text="🔌 Arduino" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="via COM port" Style="{StaticResource LabelStyle}" FontSize="10"/>
                                            </StackPanel>
                                        </RadioButton>
                                    </Border>

                                    <!-- WinWing optie -->
                                    <Border Grid.Column="2" CornerRadius="6" Padding="12,8" Cursor="Hand"
                                            BorderThickness="2"
                                            ToolTip="Map this signal to an LED on a WinWing USB HID controller">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWinWingSelected}" Value="True">
                                                        <Setter Property="Background" Value="#1A5A8FAD"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsWinWingSelected}" Value="False">
                                                        <Setter Property="Background" Value="#0A5A8FAD"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <RadioButton IsChecked="{Binding IsWinWingSelected}"
                                                     GroupName="DeviceType"
                                                     Background="Transparent"
                                                     BorderThickness="0">
                                            <StackPanel>
                                                <TextBlock Text="🕹️ WinWing" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="via USB HID" Style="{StaticResource LabelStyle}" FontSize="10"/>
                                            </StackPanel>
                                        </RadioButton>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Arduino instellingen -->
                        <Border Style="{StaticResource CardStyle}"
                                Visibility="{Binding IsArduinoSelected, Converter={StaticResource BoolToVisible}}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="ARDUINO SETTINGS" Margin="0,0,0,12"/>

                                <!-- COM Port -->
                                <TextBlock Text="COM Port" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              Style="{StaticResource DarkComboBox}"
                                              ItemsSource="{Binding AvailableComPorts}"
                                              SelectedItem="{Binding EditorComPort}"
                                              ToolTip="Select the COM port your Arduino is connected to"/>
                                    <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding RefreshDevicesCommand}"
                                            ToolTip="Refresh COM port list">
                                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14"/>
                                    </Button>
                                </Grid>

                                <!-- Pin nummer -->
                                <TextBlock Text="Pin Number" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                <metro:NumericUpDown Value="{Binding EditorPin}"
                                                     Minimum="1" Maximum="53"
                                                     Background="#1C2226"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}"
                                                     Height="32"
                                                     ToolTip="Arduino digital pin number that controls this light (1–53)"/>

                                <TextBlock Style="{StaticResource LabelStyle}"
                                           Text="Tip: Pin 13 has a built-in LED on most Arduino boards."
                                           TextWrapping="Wrap" Margin="0,8,0,0" FontStyle="Italic"/>
                                <Border Height="1" Background="#1E2529" Margin="0,16,0,12"/>

                                <!-- Board settings -->
                                <TextBlock Style="{StaticResource LabelStyle}" Text="BOARD SETTINGS" Margin="0,0,0,4"/>
                                <TextBlock Text="These settings apply to all signals on the selected COM port."
                                           Style="{StaticResource LabelStyle}" FontStyle="Italic"
                                           TextWrapping="Wrap" Margin="0,0,0,12" Opacity="0.65"/>

                                <!-- Baud Rate -->
                                <TextBlock Text="Baud Rate" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                <metro:NumericUpDown Value="{Binding BoardBaudRate}"
                                                     Minimum="1200" Maximum="2000000" Interval="9600"
                                                     Background="#1C2226"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}"
                                                     Height="32" Margin="0,0,0,12"
                                                     ToolTip="Serial baud rate. Default is 115200 for F4ToSerial."/>

                                <!-- Reset Delay -->
                                <TextBlock Text="Reset Delay (ms)" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                <metro:NumericUpDown Value="{Binding BoardResetDelayMs}"
                                                     Minimum="0" Maximum="5000" Interval="500"
                                                     Background="#1C2226"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}"
                                                     Height="32" Margin="0,0,0,4"
                                                     ToolTip="Wait time after opening the port. Arduino Leonardo: 2000 ms. ESP32: 0 ms."/>
                                <TextBlock Style="{StaticResource LabelStyle}" FontStyle="Italic" Opacity="0.65"
                                           TextWrapping="Wrap" Margin="0,0,0,12">
                                    Arduino Leonardo: 2000 ms&#x0a;ESP32 (no reset circuit): 0 ms
                                </TextBlock>

                                <!-- DTR Enable -->
                                <CheckBox IsChecked="{Binding BoardDtrEnable, Mode=TwoWay}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,0,0,4"
                                          ToolTip="Assert DTR when opening the port. Enable for Arduino Leonardo. Disable for ESP32 to prevent unwanted resets.">
                                    <TextBlock Text="Assert DTR on connect" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                </CheckBox>
                                <TextBlock Style="{StaticResource LabelStyle}" FontStyle="Italic" Opacity="0.65"
                                           TextWrapping="Wrap" Margin="20,0,0,0">
                                    &#x2713; Arduino Leonardo&#x0a;&#x2717; ESP32
                                </TextBlock>

                            </StackPanel>
                        </Border>

                        <!-- WinWing instellingen -->
                        <Border Style="{StaticResource CardStyle}"
                                Visibility="{Binding IsWinWingSelected, Converter={StaticResource BoolToVisible}}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="WINWING SETTINGS" Margin="0,0,0,12"/>

                                <!-- Controller selectie -->
                                <TextBlock Text="Controller" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              Style="{StaticResource DarkComboBox}"
                                              ItemsSource="{Binding AvailableWinWingDevices}"
                                              SelectedItem="{Binding EditorWinWingDevice}"
                                              DisplayMemberPath="Name"
                                              ToolTip="Select the WinWing controller to map this signal to"/>
                                    <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding RefreshDevicesCommand}"
                                            ToolTip="Search for WinWing devices again">
                                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14"/>
                                    </Button>
                                </Grid>

                                <!-- Geen WinWing gevonden -->
                                <Border CornerRadius="6" Background="#1AE05C6B" Padding="10,8"
                                        Margin="0,0,0,12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasWinWingDevices}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="⚠ No WinWing controllers found. Check the USB connection."
                                               Foreground="#E05C6B" FontSize="11" TextWrapping="Wrap"/>
                                </Border>

                                <!-- Lamp index -->
                                <TextBlock Text="Light" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding WinWingLightIndices}"
                                          SelectedItem="{Binding EditorLightEntry}"
                                          DisplayMemberPath="Name"
                                          ToolTip="Select which LED on the WinWing controller to control"/>


                            </StackPanel>
                        </Border>

                        <!-- Action buttons -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Add Mapping knop -->
                                <Button Style="{StaticResource PrimaryButton}"
                                        Command="{Binding AddMappingCommand}"
                                        Margin="0,0,0,8"
                                        ToolTip="Add the current output configuration as a new mapping for this signal">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14"
                                                                    VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Add Mapping" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Delete All Mappings knop -->
                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding DeleteMappingCommand}"
                                        Margin="0,0,0,8"
                                        ToolTip="Remove all mappings for this signal">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="TrashCanOutline" Width="14" Height="14"
                                                                    VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Delete All Mappings" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4,0,8"/>

                                <!-- Test button: toggles the signal ON/OFF without BMS running -->
                                <Button Command="{Binding TestSignalCommand}"
                                        ToolTip="Toggle this signal ON/OFF to test the mapped device output without BMS running.">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TestButtonIsActive}" Value="True">
                                                    <Setter Property="Background" Value="#D4881A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TestButtonIsActive}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#1E2529"/>
                                                    <Setter Property="Foreground" Value="#4A606E"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Width="14" Height="14"
                                                                    VerticalAlignment="Center" Margin="0,0,6,0">
                                            <iconPacks:PackIconMaterial.Style>
                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TestButtonIsActive}" Value="True">
                                                            <Setter Property="Kind" Value="Stop"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TestButtonIsActive}" Value="False">
                                                            <Setter Property="Kind" Value="FlashOutline"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconMaterial.Style>
                                        </iconPacks:PackIconMaterial>
                                        <TextBlock Text="{Binding TestButtonLabel}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Diagnostic button (Arduino only) -->
                                <Button Command="{Binding DiagnosticCommand}"
                                        Margin="0,6,0,0"
                                        Visibility="{Binding IsArduinoSelected, Converter={StaticResource BoolToVisible}}"
                                        ToolTip="Opens a popup showing exactly what is sent to the Arduino and whether it succeeds.">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}"/>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="BugOutline" Width="14" Height="14"
                                                                    VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Run Diagnostic" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Hint shown when no mapping exists -->
                                <TextBlock Margin="0,6,0,0" FontSize="10"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding SelectedSignal.IsMapped, Converter={StaticResource BoolToHidden}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
                                            <Setter Property="Text" Value="Add a mapping first to enable testing."/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Huidige mappings lijstje -->
                    <Border Style="{StaticResource CardStyle}"
                            Visibility="{Binding SelectedSignal.IsMapped, Converter={StaticResource BoolToVisible}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="CURRENT MAPPINGS" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding SelectedSignal.MappingRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Background="#1A2A3040" Padding="10,8"
                                                Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Ellipse Width="6" Height="6" Margin="0,0,8,0"
                                                             Fill="{StaticResource AccentBrush}"
                                                             VerticalAlignment="Center"/>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DeviceLabel}"
                                                                   Foreground="#3EC98A" FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding OutputLabel}"
                                                                   Foreground="#3EC98A" FontSize="12"
                                                                   FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Command="{Binding DeleteCommand}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Height="22" Width="22" Padding="0"
                                                        ToolTip="Remove this mapping">
                                                    <iconPacks:PackIconMaterial Kind="Close"
                                                                                Width="10" Height="10"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>


                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Brightness -->
                <TabItem Header="Brightness">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,8,0,8">

                            <!-- Controller selector -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="CONTROLLER" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  Style="{StaticResource DarkComboBox}"
                                                  ItemsSource="{Binding AvailableWinWingDevices}"
                                                  SelectedItem="{Binding SelectedBrightnessDevice, Mode=TwoWay}"
                                                  DisplayMemberPath="Name"
                                                  ToolTip="Select the WinWing controller whose backlight brightness you want to adjust"/>
                                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                                                Command="{Binding RefreshDevicesCommand}"
                                                ToolTip="Search for WinWing devices again">
                                            <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14"/>
                                        </Button>
                                    </Grid>

                                    <!-- No device warning -->
                                    <Border CornerRadius="6" Background="#1AE05C6B" Padding="10,8" Margin="0,8,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasWinWingDevices}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="⚠ No WinWing controllers found. Check the USB connection."
                                                   Foreground="#E05C6B" FontSize="11" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Brightness channels for selected controller -->
                            <Border Style="{StaticResource CardStyle}"
                                    Visibility="{Binding SelectedBrightnessDevice, Converter={StaticResource NullToCollapsed}}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="BACKLIGHT &amp; BRIGHTNESS" Margin="0,0,0,12"/>

                                    <ItemsControl ItemsSource="{Binding SelectedBrightnessChannels}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,12" Padding="12,10"
                                                        Background="#1A2226" CornerRadius="6">
                                                    <StackPanel>
                                                                                 <!-- Channel label + mode selector -->
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Label}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="13" VerticalAlignment="Center"/>
                                                            <!-- Three-way mode selector: Manual / Axis / Buttons -->
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <RadioButton Content="Manual"
                                                                             IsChecked="{Binding ModeIsManual, Mode=TwoWay}"
                                                                             GroupName="{Binding LightIndex}"
                                                                             Foreground="{StaticResource TextSecondaryBrush}"
                                                                             FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                             ToolTip="Set brightness manually using the slider below"/>
                                                                <RadioButton Content="Axis"
                                                                             IsChecked="{Binding ModeIsAxis, Mode=TwoWay}"
                                                                             GroupName="{Binding LightIndex}"
                                                                             Foreground="{StaticResource TextSecondaryBrush}"
                                                                             FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                             ToolTip="Control brightness via a joystick or throttle axis"/>
                                                                <RadioButton Content="Buttons"
                                                                             IsChecked="{Binding ModeIsButtons, Mode=TwoWay}"
                                                                             GroupName="{Binding LightIndex}"
                                                                             Foreground="{StaticResource TextSecondaryBrush}"
                                                                             FontSize="11" VerticalAlignment="Center"
                                                                             ToolTip="Control brightness by pressing two joystick buttons (step up / step down)"/>
                                                            </StackPanel>
                                                        </Grid>

                                                        <!-- Universal live brightness slider (always visible) -->
                                                        <Grid Margin="0,0,0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="36"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Manual mode: interactive slider bound to FixedBrightness -->
                                                            <Slider Grid.Column="0" Minimum="0" Maximum="255"
                                                                    Value="{Binding FixedBrightness, Mode=TwoWay}"
                                                                    IsEnabled="{Binding ModeIsManual}"
                                                                    VerticalAlignment="Center" Margin="0,0,8,0"
                                                                    ToolTip="Brightness level (0 = off, 255 = maximum)">
                                                                <Slider.Style>
                                                                    <Style TargetType="Slider">
                                                                        <Setter Property="Opacity" Value="1.0"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ModeIsManual}" Value="False">
                                                                                <Setter Property="Opacity" Value="0.65"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Slider.Style>
                                                            </Slider>
                                                            <TextBlock Grid.Column="1" Text="{Binding DisplayBrightness}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="12" VerticalAlignment="Center"
                                                                       HorizontalAlignment="Right"/>
                                                        </Grid>

                                                        <!-- Axis binding panel (visible only when Axis mode selected) -->
                                                        <StackPanel>
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ModeIsAxis}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>

                                                            <!-- Device picker -->
                                                            <TextBlock Text="Joystick" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                                            <ComboBox Style="{StaticResource DarkComboBox}"
                                                                      ItemsSource="{Binding DataContext.AvailableJoysticks,
                                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      SelectedItem="{Binding SelectedJoystick, Mode=TwoWay}"
                                                                      DisplayMemberPath="Name"
                                                                      Margin="0,0,0,8"
                                                                      ToolTip="Joystick device to read the axis from"/>

                                                            <!-- Axis detect + invert -->
                                                            <Grid Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="4"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Axis display + detect button -->
                                                                <Border Grid.Column="0" Background="#0D1A1F" CornerRadius="3"
                                                                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                                                        Padding="6,4">
                                                                    <TextBlock VerticalAlignment="Center" FontSize="12">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="{Binding SelectedAxis}"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsDetectingAxis}" Value="True">
                                                                                        <Setter Property="Text" Value="Move an axis…"/>
                                                                                        <Setter Property="Foreground" Value="#F0A500"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>
                                                                <Button Grid.Column="2"
                                                                        Command="{Binding DetectAxisCommand}"
                                                                        Padding="6,4"
                                                                        ToolTip="Click then move the axis you want to bind">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                                            <Setter Property="Content">
                                                                                <Setter.Value>
                                                                                    <iconPacks:PackIconMaterial Kind="RecordCircleOutline" Width="12" Height="12"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsDetectingAxis}" Value="True">
                                                                                    <Setter Property="Content">
                                                                                        <Setter.Value>
                                                                                            <iconPacks:PackIconMaterial Kind="RecordCircle" Width="12" Height="12"
                                                                                                                        Foreground="#F0A500"/>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <CheckBox Grid.Column="4" IsChecked="{Binding AxisInvert, Mode=TwoWay}"
                                                                          VerticalAlignment="Center"
                                                                          ToolTip="Invert axis (max physical = min brightness)">
                                                                    <TextBlock Text="Invert"
                                                                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                                                </CheckBox>
                                                            </Grid>


                                                        </StackPanel>

                                                        <!-- Button binding panel (visible when Buttons mode selected) -->
                                                        <StackPanel>
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ModeIsButtons}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>

                                                            <!-- Device picker -->
                                                            <TextBlock Text="Joystick" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                                            <ComboBox Style="{StaticResource DarkComboBox}"
                                                                      ItemsSource="{Binding DataContext.AvailableJoysticks,
                                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      SelectedItem="{Binding SelectedButtonJoystick, Mode=TwoWay}"
                                                                      DisplayMemberPath="Name"
                                                                      Margin="0,0,0,8"
                                                                      ToolTip="Joystick device for the step buttons"/>

                                                            <!-- Button Up + Button Down with press-to-detect -->
                                                            <Grid Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Button DOWN -->
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="Button Down" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="4"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0" Background="#0D1A1F" CornerRadius="3"
                                                                                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                                                                Padding="6,4">
                                                                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Text" Value="{Binding ButtonDown}"/>
                                                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsDetectingDown}" Value="True">
                                                                                                <Setter Property="Text" Value="Press a button…"/>
                                                                                                <Setter Property="Foreground" Value="#F0A500"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Border>
                                                                        <Button Grid.Column="2"
                                                                                Command="{Binding DetectButtonDownCommand}"
                                                                                Padding="6,4"
                                                                                ToolTip="Click then press the controller button you want to use for DOWN">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                                                    <Setter Property="Content">
                                                                                        <Setter.Value>
                                                                                            <iconPacks:PackIconMaterial Kind="RecordCircleOutline" Width="12" Height="12"/>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsDetectingDown}" Value="True">
                                                                                            <Setter Property="Content">
                                                                                                <Setter.Value>
                                                                                                    <iconPacks:PackIconMaterial Kind="RecordCircle" Width="12" Height="12"
                                                                                                                                Foreground="#F0A500"/>
                                                                                                </Setter.Value>
                                                                                            </Setter>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                        </Button>
                                                                    </Grid>
                                                                </StackPanel>

                                                                <!-- Button UP -->
                                                                <StackPanel Grid.Column="2">
                                                                    <TextBlock Text="Button Up" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="4"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0" Background="#0D1A1F" CornerRadius="3"
                                                                                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                                                                Padding="6,4">
                                                                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Text" Value="{Binding ButtonUp}"/>
                                                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsDetectingUp}" Value="True">
                                                                                                <Setter Property="Text" Value="Press a button…"/>
                                                                                                <Setter Property="Foreground" Value="#F0A500"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Border>
                                                                        <Button Grid.Column="2"
                                                                                Command="{Binding DetectButtonUpCommand}"
                                                                                Padding="6,4"
                                                                                ToolTip="Click then press the controller button you want to use for UP">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                                                    <Setter Property="Content">
                                                                                        <Setter.Value>
                                                                                            <iconPacks:PackIconMaterial Kind="RecordCircleOutline" Width="12" Height="12"/>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsDetectingUp}" Value="True">
                                                                                            <Setter Property="Content">
                                                                                                <Setter.Value>
                                                                                                    <iconPacks:PackIconMaterial Kind="RecordCircle" Width="12" Height="12"
                                                                                                                                Foreground="#F0A500"/>
                                                                                                </Setter.Value>
                                                                                            </Setter>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                        </Button>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- Step: velocity-based (1%–100%, no UI controls needed) -->
                                                            <TextBlock Style="{StaticResource LabelStyle}" Margin="0,2,0,0" Opacity="0.6"
                                                                       FontSize="10" FontStyle="Italic"
                                                                       Text="Step size scales with press speed: slow ~2%, fast ~25%"/>
                                                                                                                    </StackPanel>

                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Save / Reset buttons -->
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding SaveBrightnessCommand}"
                                                ToolTip="Save and apply brightness settings for this controller">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="ContentSave" Width="13" Height="13"
                                                                            VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Save" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding ResetBrightnessCommand}"
                                                ToolTip="Reset all brightness sliders to maximum (255) for this controller">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="Restore" Width="13" Height="13"
                                                                            VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Reset to default" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <!-- Saved brightness summary (mirrors CurrentMappingText style in Mapping tab) -->
                                    <Border Margin="0,10,0,0" CornerRadius="4" Background="#1A2226"
                                            Padding="10,8"
                                            Visibility="{Binding BrightnessSummaryText,
                                                Converter={StaticResource NullOrEmptyToCollapsed}}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelStyle}"
                                                       Text="SAVED SETTINGS" Margin="0,0,0,6"/>
                                            <Border CornerRadius="4" Background="#1A3EC98A" Padding="10,8">
                                                <TextBlock Text="{Binding BrightnessSummaryText}"
                                                           Foreground="#3EC98A" FontSize="12"
                                                           FontFamily="Consolas"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 3: Displays -->
                <TabItem Header="Displays">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,8,0,8">

                            <!-- ICP DED LCD section -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <iconPacks:PackIconMaterial Kind="MonitorDashboard"
                                                                    Width="16" Height="16"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="{StaticResource AccentBrush}"
                                                                    Margin="0,0,8,0"/>
                                        <TextBlock Text="WinWing ViperAce ICP — DED LCD"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource LabelStyle}"
                                               Text="Synchronises the BMS DED (Data Entry Display) to the 200×65 dot-matrix LCD on the WinWing ViperAce ICP. No SimAppPro required."
                                               TextWrapping="Wrap" Margin="0,0,0,16" FontStyle="Italic" Opacity="0.75"/>

                                    <!-- Enable toggle -->
                                    <Border CornerRadius="6" Padding="12,10"
                                            Background="#1A2226" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Enable DED LCD synchronisation"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Style="{StaticResource LabelStyle}"
                                                           Text="Reads DED data from BMS shared memory and renders it to the ICP screen."
                                                           TextWrapping="Wrap" FontSize="10" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding IcpDedEnabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      ToolTip="Enable DED text synchronisation to the ICP dot-matrix LCD screen"/>
                                        </Grid>
                                    </Border>

                                    <!-- Device status indicator -->
                                    <Border CornerRadius="6" Padding="10,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IcpIsConnected}" Value="True">
                                                        <Setter Property="Background" Value="#1A3EC98A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IcpIsConnected}" Value="False">
                                                        <Setter Property="Background" Value="#1A2226"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IcpIsConnected}" Value="True">
                                                                <Setter Property="Fill" Value="#3EC98A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IcpIsConnected}" Value="False">
                                                                <Setter Property="Fill" Value="#4A606E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <StackPanel>
                                                <TextBlock Text="ICP DEVICE" FontSize="9" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IcpIsConnected}" Value="True">
                                                                    <Setter Property="Text" Value="Connected"/>
                                                                    <Setter Property="Foreground" Value="#3EC98A"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IcpIsConnected}" Value="False">
                                                                    <Setter Property="Text" Value="Not connected"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Requirements note -->
                                    <Border CornerRadius="6" Background="#0F5A8FAD" Padding="10,8" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Requirements" FontWeight="SemiBold"
                                                       Foreground="#6B8A9A" FontSize="11" Margin="0,0,0,4"/>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11" TextWrapping="Wrap">
                                                • WinWing ViperAce ICP connected via USB&#x0a;• Sync must be active for DED updates to be sent
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Placeholder for future UFD display -->
                            <Border Style="{StaticResource CardStyle}" Opacity="0.5">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <iconPacks:PackIconMaterial Kind="MonitorDashboard"
                                                                    Width="16" Height="16"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                                    Margin="0,0,8,0"/>
                                        <TextBlock Text="WinWing UFC — DED Screen"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Border CornerRadius="4" Background="#1A2E3D4A" Padding="6,2" Margin="8,0,0,0">
                                            <TextBlock Text="COMING SOON" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="#6A7C85"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource LabelStyle}"
                                               Text="Future support for the UFC DED Screen is planned."
                                               TextWrapping="Wrap" FontStyle="Italic" Opacity="0.65"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 4: Helios -->
                <TabItem Header="Helios">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,8,0,8">

                            <!-- Launch section -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <iconPacks:PackIconMaterial Kind="ApplicationCog"
                                                                    Width="16" Height="16"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="{StaticResource AccentBrush}"
                                                                    Margin="0,0,8,0"/>
                                        <TextBlock Text="Helios Control Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource LabelStyle}"
                                               Text="Automatically launch and close a Helios profile together with BmsLightBridge sync. Helios will not be launched if it is already running."
                                               TextWrapping="Wrap" Margin="0,0,0,16" FontStyle="Italic" Opacity="0.75"/>

                                    <!-- Launch on sync start toggle -->
                                    <Border CornerRadius="6" Padding="12,10"
                                            Background="#1A2226" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Launch Helios on sync start"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Style="{StaticResource LabelStyle}"
                                                           Text="Opens Helios Control Center with the selected profile, minimised, when sync starts."
                                                           TextWrapping="Wrap" FontSize="10" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding HeliosLaunchEnabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      ToolTip="Automatically launch Helios Control Center with the selected profile when sync starts"/>
                                        </Grid>
                                    </Border>

                                    <!-- Auto shutdown toggle -->
                                    <Border CornerRadius="6" Padding="12,10"
                                            Background="#1A2226" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Close Helios on sync stop"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Style="{StaticResource LabelStyle}"
                                                           Text="Automatically closes Helios Control Center when sync stops."
                                                           TextWrapping="Wrap" FontSize="10" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding HeliosShutdownEnabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      ToolTip="Automatically close Helios Control Center when sync stops"/>
                                        </Grid>
                                    </Border>

                                    <!-- Path fields — greyed out when launch toggle is off -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HeliosLaunchEnabled}" Value="False">
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <!-- Control Center.exe path -->
                                        <TextBlock Text="Control Center.exe" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding HeliosControlCenterPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     Background="#1A2226" BorderThickness="1"
                                                     BorderBrush="{StaticResource BorderBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     Padding="6,5" CaretBrush="{StaticResource TextPrimaryBrush}"
                                                     ToolTip="Full path to Control Center.exe"
                                                     Margin="0,0,6,0" FontSize="11" IsReadOnly="True"/>
                                            <Button Grid.Column="1"
                                                    Command="{Binding BrowseHeliosExeCommand}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Browse for Control Center.exe"
                                                    Padding="10,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="FolderOpen"
                                                                                Width="13" Height="13"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,5,0"/>
                                                    <TextBlock Text="Browse" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <!-- .hpf profile path -->
                                        <TextBlock Text="Helios Profile (.hpf)" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding HeliosProfilePath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     Background="#1A2226" BorderThickness="1"
                                                     BorderBrush="{StaticResource BorderBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     Padding="6,5" CaretBrush="{StaticResource TextPrimaryBrush}"
                                                     ToolTip="Full path to your .hpf Helios profile"
                                                     Margin="0,0,6,0" FontSize="11" IsReadOnly="True"/>
                                            <Button Grid.Column="1"
                                                    Command="{Binding BrowseHeliosProfileCommand}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Browse for Helios profile (.hpf)"
                                                    Padding="10,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="FolderOpen"
                                                                                Width="13" Height="13"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,5,0"/>
                                                    <TextBlock Text="Browse" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- ================================================================
             STATUS BALK
             ================================================================ -->
        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="InformationOutline" Width="14" Height="14"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center"
                               FontSize="12"/>
                </StackPanel>

                <!-- Synchronisatie status indicator -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                        <Setter Property="Fill" Value="#3EC98A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSyncing}" Value="False">
                                        <Setter Property="Fill" Value="#4A606E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                        <Setter Property="Text" Value="Synchronisation active"/>
                                        <Setter Property="Foreground" Value="#3EC98A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSyncing}" Value="False">
                                        <Setter Property="Text" Value="Synchronisation stopped"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</metro:MetroWindow>
