<Application x:Class="BmsLightBridge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- MahApps Metro donker thema -->
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Dark.Blue.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ===== GLOBALE KLEUREN — Steel Blue Avionics ===== -->
            <!-- Achtergrond: vrijwel neutraal donker met koele blauwgrijze ondertoon -->
            <SolidColorBrush x:Key="BackgroundBrush"     Color="#181C1F"/>
            <!-- MenuBar: iets donkerder dan BackgroundBrush, voor menubalk en titelbalk -->
            <SolidColorBrush x:Key="MenuBarBrush"        Color="#141A1E"/>
            <!-- Surface: licht lichter, staalgrijs met nauwelijks zichtbare blauwtint -->
            <SolidColorBrush x:Key="SurfaceBrush"        Color="#1E2327"/>
            <!-- Card: gedempte blauwgrijze toon, subtiel afstekend -->
            <SolidColorBrush x:Key="CardBrush"           Color="#242A2E"/>
            <!-- Input: achtergrond voor invoervelden (TextBox, ComboBox, NumericUpDown) -->
            <SolidColorBrush x:Key="InputBrush"          Color="#1C2226"/>
            <!-- Accent: gedempte staalblauwe toon — functioneel, niet schreeuwend -->
            <SolidColorBrush x:Key="AccentBrush"         Color="#6B8A9A"/>
            <!-- Groen behouden voor actieve status -->
            <SolidColorBrush x:Key="AccentGreenBrush"    Color="#3EC98A"/>
            <!-- Rood behouden voor fout/stop -->
            <SolidColorBrush x:Key="AccentRedBrush"      Color="#E05C6B"/>
            <!-- Amber voor detectie-animaties (axis/button detect in progress) -->
            <SolidColorBrush x:Key="AccentAmberBrush"    Color="#F0A500"/>
            <!-- Primaire tekst: lichtgrijs met minimale koele tint, hoog leesbaar -->
            <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#C2CACF"/>
            <!-- Secundaire tekst: gedempte blauwgrijs — leesbaar maar teruggetrokken -->
            <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#6A7C85"/>
            <!-- Border: subtiele scheidingslijn, nauwelijks zichtbaar maar aanwezig -->
            <SolidColorBrush x:Key="BorderBrush"         Color="#2D373D"/>

            <!-- Alpha-tint achtergronden voor status- en info-banners -->
            <SolidColorBrush x:Key="BannerRedBrush"      Color="#1AE05C6B"/>
            <SolidColorBrush x:Key="BannerGreenBrush"    Color="#1A3EC98A"/>
            <SolidColorBrush x:Key="BannerBlueBrush"     Color="#0F5A8FAD"/>
            <SolidColorBrush x:Key="BannerGreenDarkBrush" Color="#1A3D2B"/>
            <SolidColorBrush x:Key="BannerGreenDarkBorder" Color="#2A6B45"/>
            <SolidColorBrush x:Key="BannerNeutralBrush"  Color="#1A2E3D4A"/>
            <!-- Lichte groentint voor secundaire DED-tekst -->
            <SolidColorBrush x:Key="TextGreenDimBrush"   Color="#5FD99A"/>

            <!-- ===== GLOBALE STIJLEN ===== -->

            <!-- Standaard tekst -->
            <Style TargetType="TextBlock" x:Key="LabelStyle">
                <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontSize"    Value="11"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
            </Style>

            <!-- Kaart / paneel stijl -->
            <Style TargetType="Border" x:Key="CardStyle">
                <Setter Property="Background"       Value="{StaticResource CardBrush}"/>
                <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness"  Value="1"/>
                <Setter Property="CornerRadius"     Value="8"/>
                <Setter Property="Padding"          Value="16"/>
                <Setter Property="Margin"           Value="0,0,0,12"/>
            </Style>

            <!-- Primaire knop -->
            <Style TargetType="Button" x:Key="PrimaryButton">
                <Setter Property="Background"   Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground"   Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"      Value="16,8"/>
                <Setter Property="FontWeight"   Value="SemiBold"/>
                <Setter Property="FontSize"     Value="13"/>
                <Setter Property="Cursor"       Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#5A7A88"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#4A6A78"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#1E2529"/>
                                    <Setter Property="Foreground" Value="#586870"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Groene start knop -->
            <Style TargetType="Button" x:Key="StartButton" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#33B07A"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Rode stop knop -->
            <Style TargetType="Button" x:Key="StopButton" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#CC4A58"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Secundaire knop (outline) -->
            <Style TargetType="Button" x:Key="SecondaryButton">
                <Setter Property="Background"       Value="Transparent"/>
                <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness"  Value="1"/>
                <Setter Property="Padding"          Value="12,6"/>
                <Setter Property="FontSize"         Value="12"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#20292E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBox stijl -->
            <Style TargetType="ComboBox" x:Key="DarkComboBox">
                <Setter Property="Background"      Value="{StaticResource InputBrush}"/>
                <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="8,4"/>
                <Setter Property="Height"          Value="32"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              Background="{StaticResource InputBrush}"
                                              BorderBrush="{StaticResource BorderBrush}"
                                              BorderThickness="1"
                                              Padding="8,4"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Grid.Column="0"
                                                                      Margin="{TemplateBinding Padding}"
                                                                      HorizontalAlignment="Left"
                                                                      VerticalAlignment="Center"/>
                                                    <Path Grid.Column="1"
                                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                                          Fill="{StaticResource TextSecondaryBrush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#20292E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <ContentPresenter/>
                                </ToggleButton>
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  Margin="10,0,24,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  TextBlock.Foreground="{StaticResource TextPrimaryBrush}"
                                                  TextBlock.FontSize="12"/>
                                <Popup x:Name="Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                    <Grid MinWidth="{TemplateBinding ActualWidth}"
                                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border Background="{StaticResource InputBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <ScrollViewer>
                                                <StackPanel IsItemsHost="True"
                                                            KeyboardNavigation.DirectionalNavigation="Contained"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
                            <Setter Property="Padding"    Value="8,6"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter Property="Background" Value="#2A4450"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBox stijl -->
            <Style TargetType="TextBox" x:Key="DarkTextBox">
                <Setter Property="Background"   Value="{StaticResource InputBrush}"/>
                <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CaretBrush"   Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Padding"      Value="6,5"/>
                <Setter Property="FontSize"     Value="12"/>
                <Setter Property="Height"       Value="32"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- NumericUpDown stijl (MahApps) -->
            <Style TargetType="metro:NumericUpDown" x:Key="DarkNumericUpDown">
                <Setter Property="Background"   Value="{StaticResource InputBrush}"/>
                <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
                <Setter Property="Height"       Value="32"/>
                <Setter Property="FontSize"     Value="12"/>
            </Style>

            <!-- Toggle row: bordered panel met checkbox en label -->
            <Style TargetType="Border" x:Key="ToggleRowStyle">
                <Setter Property="CornerRadius"     Value="6"/>
                <Setter Property="Padding"          Value="12,10"/>
                <Setter Property="Background"       Value="{StaticResource InputBrush}"/>
                <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness"  Value="1"/>
            </Style>

            <!-- DarkDisplayBox: read-only waardedisplay (geselecteerde as, knopnummer, etc.) -->
            <Style TargetType="Border" x:Key="DarkDisplayBox">
                <Setter Property="Background"      Value="{StaticResource BackgroundBrush}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="3"/>
                <Setter Property="Padding"         Value="6,4"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
